# === Model & Artifacts ===
# Path to the serialized model file (relative to project root)
MODEL_PATH=artifacts/model.pkl

# Path to the serialized preprocessor file
PREPROCESSOR_PATH=artifacts/preprocessor.pkl

# === Logging ===
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Path to log file (leave empty to log to console only)
LOG_FILE=logs/app.log

# === API Server ===
HOST=0.0.0.0
PORT=8000

# === Security ===
# API key for /predict endpoint (set a real secret in production, never commit .env)
API_KEY=your_key_here
